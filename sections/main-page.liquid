{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | escape }}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>
  {% form 'customer_address', customer.new_address, id: 'address_form_new' %}
  <!-- form content -->
  {% endform %}
</div>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    console.log('Main page script loaded');
    const companyName = localStorage.getItem('custom_field_company');
    const companyNameMetafieldKey = localStorage.getItem('custom_field_company_number_metafield_key');
    const customerId = {{ customer.id | json }};
    console.log('Company Name:', companyName);
    console.log('Company companyNameMetafieldKey:', companyNameMetafieldKey);
    if(companyName) {
      console.log('Company Name:', companyName);
      sendMetafield(companyNameMetafieldKey, companyName, customerId);
      localStorage.removeItem('custom_field_company');
      localStorage.removeItem('custom_field_company_number_metafield_key');
    }

    const clientNumber = localStorage.getItem('custom_field_client_number');
    const clientNumberMetafieldKey = localStorage.getItem('custom_field_client_number_metafield_key');

    if(clientNumber) {
      console.log('Client Number:', clientNumber);
      sendMetafield(clientNumberMetafieldKey, clientNumber, customerId);
      localStorage.removeItem('custom_field_client_number');
      localStorage.removeItem('custom_field_client_number_metafield_key');
    }

    if (document.querySelector("#address_form_new")) {
      sendAddress();
    }
  });

  function sendAddress() {
    console.log("sendAddress");
    const clientAddress1 = localStorage.getItem('custom_field_default_address1');
    const clientCity = localStorage.getItem('custom_field_default_city');
    const clientCountry = localStorage.getItem('custom_field_default_country');
    {% comment %} const clientProvince = localStorage.getItem('custom_field_default_province'); {% endcomment %}
    const clientZip = localStorage.getItem('custom_field_default_zip');
    const clientPhone = localStorage.getItem('custom_field_default_phone');
    const clientEmail = localStorage.getItem('custom_field_default_email');
    const clientFirstName = localStorage.getItem('custom_field_default_first_name');
    const clientLastName = localStorage.getItem('custom_field_default_last_name');
    const companyName = localStorage.getItem('custom_field_company') || '';

    console.log(clientAddress1,clientCity,clientCountry,clientZip,clientPhone,clientEmail,clientFirstName,clientLastName,companyName);
    // Only proceed if email matches and required fields exist
    if (clientEmail && clientAddress1 && clientCity && clientCountry && clientZip) {
      const addressForm = document.querySelector("#address_form_new");
      if (!addressForm) {
        console.error("Address form not found on page.");
        return;
      }

      console.log("client email : ", clientEmail);
      const formData = new FormData(addressForm);
      formData.set('address[address1]', clientAddress1);
      formData.set('address[city]', clientCity);
      formData.set('address[country]', clientCountry);
      {% comment %} formData.set('address[province]', clientProvince); {% endcomment %}
      formData.set('address[zip]', clientZip);
      formData.set('address[phone]', clientPhone || '');
      formData.set('address[first_name]', clientFirstName || '');
      formData.set('address[last_name]', clientLastName || '');
      formData.set('address[company]', companyName);

      fetch("/account/addresses", {
        method: "POST",
        body: formData,
        headers: { "X-Requested-With": "XMLHttpRequest" }
      })
      .then(response => response.text())  // <- use text instead of json
      .then(data => {
        console.log("Address update response:", data);
      })
      .catch(error => console.error("Address update error:", error))
      .finally(() => {
        // Clean up localStorage
        localStorage.removeItem('custom_field_default_address1');
        localStorage.removeItem('custom_field_default_city');
        localStorage.removeItem('custom_field_default_country');
        {% comment %} localStorage.removeItem('custom_field_default_province'); {% endcomment %}
        localStorage.removeItem('custom_field_default_zip');
        localStorage.removeItem('custom_field_default_phone');
        localStorage.removeItem('custom_field_default_email');
        localStorage.removeItem('custom_field_default_first_name');
        localStorage.removeItem('custom_field_default_last_name');
      });

    }
  }

 
  function sendMetafield(metafieldKey, metafieldValue, customerId) {
    const namespace = 'custom';

    if(metafieldKey && metafieldValue) {
      const formData = new FormData();
      formData.append('action', 'save_metafield');
      formData.append('customer_id', customerId);
      formData.append('metafield_key', metafieldKey);
      formData.append('metafield_value', metafieldValue);
      formData.append('namespace', namespace);

      fetch('https://shopify.clearlablens.com/clearlabes/metafields/', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        {% comment %} console.log('Success:', data); {% endcomment %}
        {% comment %} sendAddress(); {% endcomment %}
      })
      .catch((error) => {
        console.error('Error:', error);
      });
    }
  }
</script>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
