{% schema %}
{
  "name": "Video + Image Slideshow",
  "settings": [
    {
      "type": "header",
      "content": "Slide 1"
    },
    {
      "type": "select",
      "id": "slide_1_type",
      "label": "Slide 1 Type",
      "options": [
        { "value": "video", "label": "Video" },
        { "value": "image", "label": "Image" }
      ],
      "default": "video"
    },
    {
      "type": "text",
      "id": "slide_1_video",
      "label": "Slide 1 Video URL (MP4)",
      "default": "https://cdn.shopify.com/videos/c/o/v/4a2f92df97544cb2a1b28bae512334ef.mp4"
    },
    {
      "type": "image_picker",
      "id": "slide_1_image",
      "label": "Slide 1 Image"
    },

    {
      "type": "header",
      "content": "Slide 2"
    },
    {
      "type": "select",
      "id": "slide_2_type",
      "label": "Slide 2 Type",
      "options": [
        { "value": "video", "label": "Video" },
        { "value": "image", "label": "Image" }
      ],
      "default": "image"
    },
    {
      "type": "text",
      "id": "slide_2_video",
      "label": "Slide 2 Video URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "slide_2_image",
      "label": "Slide 2 Image"
    },

    {
      "type": "header",
      "content": "Slide 3"
    },
    {
      "type": "select",
      "id": "slide_3_type",
      "label": "Slide 3 Type",
      "options": [
        { "value": "video", "label": "Video" },
        { "value": "image", "label": "Image" }
      ],
      "default": "video"
    },
    {
      "type": "text",
      "id": "slide_3_video",
      "label": "Slide 3 Video URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "slide_3_image",
      "label": "Slide 3 Image"
    }
  ],
  "presets": [
    {
      "name": "Video + Image Slideshow"
    }
  ]
}
{% endschema %}
<div class="page-width">
    <div class="video-slideshow">
    <div class="slides">
        {% for i in (1..3) %}
        {% assign type_id = 'slide_' | append: i | append: '_type' %}
        {% assign video_id = 'slide_' | append: i | append: '_video' %}
        {% assign image_id = 'slide_' | append: i | append: '_image' %}

        {% if section.settings[type_id] == 'video' and section.settings[video_id] != blank %}
            <div class="slide{% if forloop.first %} active{% endif %}">
            <video autoplay muted loop playsinline>
                <source src="{{ section.settings[video_id] }}" type="video/mp4">
            </video>
            </div>
        {% elsif section.settings[type_id] == 'image' and section.settings[image_id] != blank %}
            <div class="slide{% if forloop.first %} active{% endif %}">
            <img src="{{ section.settings[image_id] | image_url: width: 1920 }}" alt="Slide {{ i }}" loading="lazy">
            </div>
        {% endif %}
        {% endfor %}
    </div>

    <div class="controls">
        <button class="prev" aria-label="Previous slide">‹</button>
        <button class="next" aria-label="Next slide">›</button>
    </div>
    </div>
</div>

<style>
.video-slideshow {
  position: relative;
  width: 100%;
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  overflow: hidden;
  border-radius: var(--radius-large, 16px);
}

.video-slideshow .slides {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
}

.video-slideshow video,
.video-slideshow img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: inherit;
}

.video-slideshow .slide {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0;
  transition: opacity 1s ease-in-out;
}

.video-slideshow .slide.active {
  opacity: 1;
  z-index: 2;
}

.video-slideshow .controls {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 20px;
  z-index: 3;
}

.video-slideshow button {
  background: rgba(255, 255, 255, 0.4);
  border: none;
  color: #000;
  font-size: 2rem;
  width: 50px; height: 50px;
  border-radius: 50%;
  cursor: pointer;
  transition: background 0.3s;
}

.video-slideshow button:hover {
  background: rgba(255, 255, 255, 0.7);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const slides = document.querySelectorAll('.video-slideshow .slide');
  const nextBtn = document.querySelector('.video-slideshow .next');
  const prevBtn = document.querySelector('.video-slideshow .prev');
  let current = 0;

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.classList.toggle('active', i === index);
    });
  }

  nextBtn.addEventListener('click', () => {
    current = (current + 1) % slides.length;
    showSlide(current);
  });

  prevBtn.addEventListener('click', () => {
    current = (current - 1 + slides.length) % slides.length;
    showSlide(current);
  });
});
</script>
